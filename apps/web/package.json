{
  "name": "@barbord/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "prebuild": "pnpm --filter @barbord/contract build && pnpm --filter @barbord/gateway build",
    "build": "vite build",
    "start": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "oxlint *.ts -c ../../.oxlintrc.json",
    "format": "oxfmt *.ts -c ../../.oxfmtrc.json",
    "format:check": "oxfmt --check *.ts -c ../../.oxfmtrc.json"
  },
  "dependencies": {
    "@barbord/contract": "workspace:*",
    "@barbord/gateway": "workspace:*",
    "clsx": "^2.1.1",
    "lucide-svelte": "^0.577.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/api": "^2.10.1",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.52.0",
    "oxlint-tsgolint": "^0.16.0",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "sveltekit-superforms": "^2.30.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  },
  "overrides": {
    "@tailwindcss/vite": {
      "vite": "^8.0.0"
    }
  },
  "engines": {
    "node": "=22",
    "pnpm": "=10"
  }
}