{
  "name": "@barbord/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "oxlint -c ../../.oxlintrc.json",
    "format": "oxfmt -c ../../.oxfmtrc.json",
    "format:check": "oxfmt --check -c ../../.oxfmtrc.json"
  },
  "dependencies": {
    "@barbord/contract": "workspace:*",
    "@barbord/gateway": "workspace:*",
    "clsx": "catalog:",
    "lucide-svelte": "catalog:",
    "tailwind-merge": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "catalog:",
    "@sveltejs/kit": "catalog:",
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@tailwindcss/forms": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tauri-apps/api": "^2.10.1",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "svelte": "catalog:",
    "svelte-check": "catalog:",
    "sveltekit-superforms": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "overrides": {
    "@tailwindcss/vite": {
      "vite": "catalog:"
    }
  },
  "engines": {
    "node": "=22",
    "pnpm": "=10"
  }
}