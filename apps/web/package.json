{
  "name": "@barbord/web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "prebuild": "pnpm --filter @barbord/contract build && pnpm --filter @barbord/gateway build",
    "build": "vite build",
    "start": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "oxlint *.ts -c ../../.oxlintrc.json",
    "format": "oxfmt *.ts -c ../../.oxfmtrc.json",
    "format:check": "oxfmt --check *.ts -c ../../.oxfmtrc.json"
  },
  "engines": {
    "node": "=22",
    "pnpm": "=10"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.1.18",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.52.0",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-devtools-json": "^1.0.0"
  },
  "dependencies": {
    "@barbord/contract": "workspace:*",
    "@barbord/gateway": "workspace:*",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  }
}
