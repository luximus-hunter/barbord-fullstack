{
  "name": "barbord-fullstack",
  "private": true,
  "packageManager": "pnpm@10.32.0+sha512.9b2634bb3fed5601c33633f2d92593f506270a3963b8c51d2b2d6a828da615ce4e9deebef9614ccebbc13ac8d3c0f9c9ccceb583c69c8578436fa477dbb20d70",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:libs": "turbo build --filter @barbord/contract --filter @barbord/gateway --filter @barbord/db",
    "start": "turbo start",
    "db:generate": "pnpm --filter @barbord/db generate",
    "db:push": "pnpm --filter @barbord/db push",
    "api:dev": "pnpm --filter @barbord/api dev",
    "api:build": "pnpm --filter @barbord/api build",
    "api:generate": "pnpm --filter @barbord/api run generate",
    "api:start": "pnpm --filter @barbord/api start",
    "web:dev": "turbo dev --filter @barbord/web --filter @barbord/api",
    "web:build": "pnpm --filter @barbord/web build",
    "web:start": "pnpm --filter @barbord/web start",
    "lint": "turbo run lint",
    "format": "turbo run format"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "tsdown": "^0.15.6"
  }
}
