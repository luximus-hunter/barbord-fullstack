{
  "name": "barbord-fullstack",
  "private": true,
  "packageManager": "pnpm@10.30.0+sha512.2b5753de015d480eeb88f5b5b61e0051f05b4301808a82ec8b840c9d2adf7748eb352c83f5c1593ca703ff1017295bc3fdd3119abb9686efc96b9fcb18200937",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "db:generate": "pnpm --filter @barbord/db generate",
    "db:push": "pnpm --filter @barbord/db push",
    "api:dev": "pnpm --filter @barbord/api dev",
    "api:build": "pnpm --filter @barbord/api build",
    "api:generate": "pnpm --filter @barbord/api run generate",
    "api:start": "pnpm --filter @barbord/api start",
    "web:dev": "turbo dev --filter @barbord/web --filter @barbord/api",
    "web:build": "pnpm --filter @barbord/web build",
    "web:start": "pnpm --filter @barbord/web start"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "tsdown": "^0.15.6"
  }
}
