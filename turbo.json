{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": [
        "DATABASE_URL",
        "BLOB_READ_WRITE_TOKEN",
        "CRON_SECRET",
        "JWT_SECRET",
        "RESEND_SENDER_EMAIL",
        "RESEND_API_KEY",
        "GITHUB_REPO_TOKEN",
        "VITE_API_BASE_URL"
      ]
    },
    "dev": {
      "dependsOn": [
        "@barbord/contract#build",
        "@barbord/gateway#build",
        "@barbord/db#build"
      ],
      "cache": false,
      "persistent": true,
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "env": [
        "DATABASE_URL",
        "BLOB_READ_WRITE_TOKEN",
        "CRON_SECRET",
        "JWT_SECRET",
        "RESEND_SENDER_EMAIL",
        "RESEND_API_KEY",
        "GITHUB_REPO_TOKEN",
        "VITE_API_BASE_URL"
      ]
    },
    "@barbord/desktop#build": {
      "dependsOn": ["@barbord/web#build"],
      "outputs": ["apps/desktop/src-tauri/target/**/*"]
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true,
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "env": [
        "DATABASE_URL",
        "BLOB_READ_WRITE_TOKEN",
        "CRON_SECRET",
        "JWT_SECRET",
        "RESEND_SENDER_EMAIL",
        "RESEND_API_KEY",
        "GITHUB_REPO_TOKEN",
        "VITE_API_BASE_URL"
      ]
    },
    "lint": {
      "cache": false,
      "inputs": ["src/**/*.ts"]
    },
    "format": {
      "cache": false,
      "inputs": ["src/**/*.ts"]
    }
  }
}