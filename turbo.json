{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "!.turbo/**"],
      "env": [
        "DATABASE_URL",
        "BLOB_READ_WRITE_TOKEN",
        "CRON_SECRET",
        "JWT_SECRET",
        "RESEND_SENDER_EMAIL",
        "RESEND_API_KEY",
        "GITHUB_REPO_TOKEN"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "env": [
        "DATABASE_URL",
        "BLOB_READ_WRITE_TOKEN",
        "CRON_SECRET",
        "JWT_SECRET",
        "RESEND_SENDER_EMAIL",
        "RESEND_API_KEY",
        "GITHUB_REPO_TOKEN"
      ]
    },
    "desktop#build": {
      "dependsOn": ["web#build"]
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true,
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "env": [
        "DATABASE_URL",
        "BLOB_READ_WRITE_TOKEN",
        "CRON_SECRET",
        "JWT_SECRET",
        "RESEND_SENDER_EMAIL",
        "RESEND_API_KEY",
        "GITHUB_REPO_TOKEN"
      ]
    }
  }
}
