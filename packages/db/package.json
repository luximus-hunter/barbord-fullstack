{
  "name": "@barbord/db",
  "version": "1.0.0",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsdown --watch --config ../../tsdown.config.ts",
    "build": "tsdown --config ../../tsdown.config.ts",
    "postinstall": "prisma generate",
    "generate": "dotenv -e .env.development -- prisma generate",
    "push": "dotenv -e .env.development -- prisma db push",
    "lint": "oxlint -c ../../.oxlintrc.json",
    "format": "oxfmt -c ../../.oxfmtrc.json",
    "format:check": "oxfmt --check -c ../../.oxfmtrc.json"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "catalog:",
    "@prisma/client": "catalog:",
    "dotenv": "catalog:",
    "prisma": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "dotenv-cli": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.29.3",
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}